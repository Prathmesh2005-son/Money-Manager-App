<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/friendCard"
    android:orientation="vertical"
    android:background="@drawable/shape_card_bg"
    android:padding="12dp"
    android:layout_margin="8dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Header row: name, total, expand icon -->
    <LinearLayout
        android:id="@+id/friendHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <TextView
                android:id="@+id/friendName"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/primary_dark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/friendTotal"
                android:textSize="15sp"
                android:textColor="@color/primary_text"
                android:layout_marginTop="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <ImageView
            android:id="@+id/expandIcon"
            android:src="@drawable/ic_expand_more_24"
            android:contentDescription="expand"
            android:layout_width="24dp"
            android:layout_height="24dp" />
    </LinearLayout>

    <!-- Transactions container -->
    <LinearLayout
        android:id="@+id/txnContainer"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTransactions"
            android:nestedScrollingEnabled="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>

</LinearLayout>
